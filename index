                        <div className="flex gap-4">
                            <div className="bg-slate-100 p-3 rounded-full h-fit flex-shrink-0">
                                <IcClip size={16} className="text-slate-600" style={{stroke:'#475569'}}/>
                            </div>
                            <div>
                                <h4 className="font-700 text-slate-800 mb-1 text-sm" style={{fontWeight:700}}>Revisión Operativa (MBR)</h4>
