                                    <span className="text-sm font-700 text-white" style={{fontWeight:700}}>{p.pnlImpact}</span>
                                </div>
                            </div>
                        );
                    })}
                </div>

                {/* Gobierno */}
                <div className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-6 border-t-4 border-t-amber-500">
                    <div className="px-6 py-4 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
                        <div className="flex items-center gap-2">
                            <IcCalCheck size={16} className="text-amber-600" style={{stroke:'#d97706'}}/>
