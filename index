    <style>
        * { font-family: 'DM Sans', sans-serif; box-sizing: border-box; }
        code, .mono { font-family: 'DM Mono', monospace; }
        body { background: #f5f4f0; min-height: 100vh; }

        /* Scrollbar */
        .gantt-scroll::-webkit-scrollbar { height: 6px; }
        .gantt-scroll::-webkit-scrollbar-track { background: transparent; }
        .gantt-scroll::-webkit-scrollbar-thumb { background: #c8c5bc; border-radius: 4px; }

        /* Q background bands */
        .q-band-q1 { background: rgba(59,130,246,0.04); }
        .q-band-q2 { background: rgba(16,185,129,0.04); }
        .q-band-q3 { background: rgba(245,158,11,0.04); }
        .q-band-q4 { background: rgba(139,92,246,0.04); }

        /* Row expand animation */
        .detail-panel { 
            max-height: 0; overflow: hidden;
            transition: max-height 0.35s ease, opacity 0.3s ease;
            opacity: 0;
        }
        .detail-panel.open { max-height: 400px; opacity: 1; }

        /* Gantt bar */
        .gantt-bar {
            height: 22px;
            border-radius: 4px;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            transition: filter 0.15s ease;
        }
        .gantt-bar:hover { filter: brightness(1.08); }

        /* Milestone diamond */
        .milestone {
            width: 12px; height: 12px;
            transform: rotate(45deg) translateY(-50%);
            position: absolute;
            top: 50%;
            margin-top: -6px;
            border-radius: 2px;
            z-index: 10;
        }

        /* Row hover */
        .gantt-row { transition: background 0.15s ease; }
        .gantt-row:hover { background: rgba(0,0,0,0.018); }
        .gantt-row.expanded { background: rgba(0,0,0,0.025); }

        /* Toggle switch */
        .toggle-pill {
            background: #1e1b18;
            border-radius: 99px;
            padding: 3px;
            display: inline-flex;
            gap: 2px;
        }
        .toggle-pill button {
            border-radius: 99px;
            padding: 5px 16px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.02em;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        .toggle-pill button.active { background: #fff; color: #1e1b18; }
        .toggle-pill button:not(.active) { background: transparent; color: rgba(255,255,255,0.5); }

        /* Status RAG dots */
        .rag-verde { background: #10b981; }
        .rag-amarillo { background: #f59e0b; }
        .rag-rojo { background: #ef4444; }

        /* Sticky left panel */
        .left-panel { width: 240px; min-width: 240px; flex-shrink: 0; }

        /* Category pills */
        .cat-banco { background: #dbeafe; color: #1d4ed8; }
        .cat-crosssell { background: #ede9fe; color: #6d28d9; }
        .cat-oper { background: #f1f5f9; color: #475569; }

        /* Badge */
        .badge-liberado { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        .badge-encurso { background: #dbeafe; color: #1e40af; border: 1px solid #93c5fd; }
        .badge-banco2 { background: #ede9fe; color: #5b21b6; border: 1px solid #c4b5fd; }
        .badge-pendiente { background: #fef9c3; color: #854d0e; border: 1px solid #fde68a; }

        .note-tbd { color: #92400e; background: #fef3c7; border-left: 3px solid #f59e0b; font-size: 11px; padding: 4px 8px; border-radius: 0 4px 4px 0; }

