        .accordion-content { 
            max-height: 0; overflow: hidden;
            transition: max-height 0.4s ease-in-out, opacity 0.4s ease-in-out;
            opacity: 0;
        }
        .accordion-content.open { max-height: 600px; opacity: 1; }
