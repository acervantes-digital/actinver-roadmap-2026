                                        <th className="px-6 py-3 font-700 text-slate-700" style={{fontWeight:700}}>KPIs Secundarios</th>
                                    </tr>
                                </thead>
                                <tbody className="divide-y divide-slate-100">
                                    <tr className="hover:bg-slate-50">
                                        <td className="px-6 py-3 font-700 text-blue-700" style={{fontWeight:700}}><div className="flex items-center gap-2"><div className="w-2 h-2 rounded-full bg-blue-500"/>Principalidad</div></td>
                                        <td className="px-6 py-3 text-slate-600">Costo de Fondeo (Intereses)</td>
                                        <td className="px-6 py-3 font-700 text-slate-800 bg-blue-50/30" style={{fontWeight:700}}>70% MAU / 50% Transaccionales</td>
                                        <td className="px-6 py-3 text-slate-600"><ul className="list-disc pl-4 space-y-1"><li><strong>Saldo Promedio Vista:</strong> Tasa de Fondeo</li><li><strong>Portabilidad:</strong> # de nóminas</li><li><strong>Pagos Promedio:</strong> Recurrencia mensual</li><li><strong>NPS Digital:</strong> Satisfacción y lealtad</li></ul></td>
                                    </tr>
                                    <tr className="hover:bg-slate-50">
                                        <td className="px-6 py-3 font-700 text-purple-700" style={{fontWeight:700}}><div className="flex items-center gap-2"><div className="w-2 h-2 rounded-full bg-purple-500"/>Ingreso Directo</div></td>
                                        <td className="px-6 py-3 text-slate-600">Margen Financiero + Comisiones</td>
                                        <td className="px-6 py-3 font-700 text-slate-800 bg-purple-50/30" style={{fontWeight:700}}>25% Tasa de Conversión General</td>
                                        <td className="px-6 py-3 text-slate-600"><ul className="list-disc pl-4 space-y-1"><li><strong>Revenue Generado:</strong> Margen + Fees</li><li><strong>Monto Colocado:</strong> Cartera crédito activa</li><li><strong>*Primas Emitidas:</strong> Venta seguros</li><li><strong>Actinver Trade:</strong> P&L objetivo</li></ul></td>
                                    </tr>
                                    <tr className="hover:bg-slate-50">
                                        <td className="px-6 py-3 font-700 text-slate-700" style={{fontWeight:700}}><div className="flex items-center gap-2"><div className="w-2 h-2 rounded-full bg-slate-500"/>Eficiencia</div></td>
                                        <td className="px-6 py-3 text-slate-600">Gastos de Operación (OpEx)</td>
                                        <td className="px-6 py-3 font-700 text-slate-800 bg-slate-50/30" style={{fontWeight:700}}>-50% Contacto CAT (Token)</td>
                                        <td className="px-6 py-3 text-slate-600"><ul className="list-disc pl-4 space-y-1"><li><strong>% Adopción Digital:</strong> Migración a Banca Móvil</li><li><strong>Tasa de Fraude:</strong> Pérdidas evitadas</li><li><strong>Call Deflection:</strong> Menos llamadas operativas al CAT</li></ul></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <p className="text-center text-[10px] text-slate-400 italic pb-4">Documento confidencial para uso interno de Actinver.</p>
            </div>
        );
    };

    // ── APP ──────────────────────────────────────────────────────────────────
    const App = () => {
        const [view, setView] = useState('gantt');

        return (
            <div className="min-h-screen" style={{background:'#f5f4f0'}}>
                {/* Top bar */}
                <div className="sticky top-0 z-50 bg-white border-b border-slate-200 shadow-sm">
                    <div className="flex items-center justify-between px-6 py-3">
                        <div className="flex items-center gap-3">
                            <div className="w-7 h-7 rounded-lg bg-slate-900 flex items-center justify-center">
                                <IcTarget size={14} className="text-white"/>
                            </div>
                            <div>
                                <h1 className="text-slate-900 leading-none" style={{fontWeight:800, fontSize:'20px', letterSpacing:'-0.02em'}}>Actinver Digital</h1>
                                <p className="text-slate-400 leading-none mt-0.5" style={{fontWeight:500, fontSize:'11px'}}>Roadmap 2026 · Actualización Abr 26</p>
                            </div>
                        </div>
                        <div className="toggle-pill">
                            <button className={view === 'gantt' ? 'active' : ''} onClick={() => setView('gantt')}>
                                🗓 Roadmap
                            </button>
                            <button className={view === 'status' ? 'active' : ''} onClick={() => setView('status')}>
                                📋 Status
                            </button>
                            <button className={view === 'valor' ? 'active' : ''} onClick={() => setView('valor')}>
                                💡 Modelo de Valor
                            </button>
                        </div>
                    </div>
                </div>

                {/* Content */}
                <div className={view === 'gantt' ? '' : 'py-4'}>
                    {view === 'gantt' ? <GanttView/> : view === 'status' ? <StatusView/> : <ValorView/>}
                </div>

                <footer className="text-center py-6">
                    <p className="text-[10px] text-slate-400 italic">Plan tentativo sujeto a cambios por priorización, capacidad técnica y reestimaciones.</p>
                </footer>
            </div>
        );
    };

    ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
