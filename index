                                <IcTarget size={16} style={{stroke:'#d97706'}}/>
                            </div>
                            <div>
                                <h4 className="font-700 text-slate-800 mb-1 text-sm" style={{fontWeight:700}}>Revisión Estratégica (QBR)</h4>
