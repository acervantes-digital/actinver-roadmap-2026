                                    </div>
                                    {/* Drivers */}
                                    <div className="mb-4 flex-grow">
                                        <p className="text-[10px] font-700 text-slate-400 uppercase mb-2 flex items-center gap-1" style={{fontWeight:700}}>
                                            <IcTarget size={10}/> Drivers (Proyectos Clave)
                                        </p>
                                        <ul className="space-y-1.5">
                                            {p.drivers.map((d, i) => (
                                                <li key={i} className="flex items-center justify-between text-xs text-slate-700 border-b border-dashed border-slate-100 pb-1 last:border-0">
                                                    <div className="flex items-center gap-1.5">
                                                        <div className={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${t.iconBg}`}/>
                                                        <span>{d.name}</span>
                                                    </div>
                                                    <span className={`text-[9px] font-700 px-1.5 py-0.5 rounded ml-2 whitespace-nowrap ${t.dateBg}`} style={{fontWeight:700}}>{d.date}</span>
                                                </li>
                                            ))}
                                        </ul>
                                    </div>
                                    {/* KPIs */}
                                    <div>
                                        <p className="text-[10px] font-700 text-slate-400 uppercase mb-2 flex items-center gap-1" style={{fontWeight:700}}>
                                            <IcTrophy size={10}/> Objetivos Anuales 2026
                                        </p>
                                        <div className="space-y-1.5">
                                            {p.kpis.map((k, i) => (
                                                <div key={i} className={`px-3 py-2 rounded border ${t.bg} ${t.border} flex justify-between items-center`}>
                                                    <div>
                                                        <span className={`text-xs font-700 ${t.text}`} style={{fontWeight:700}}>{k.label}</span>
                                                        <p className="text-[9px] text-slate-400 uppercase tracking-wide">Meta Anual</p>
                                                    </div>
                                                    <span className={`text-sm font-700 ${t.text} bg-white/50 px-2 py-1 rounded shadow-sm ml-2`} style={{fontWeight:700}}>{k.detail}</span>
                                                </div>
                                            ))}
                                        </div>
                                    </div>
