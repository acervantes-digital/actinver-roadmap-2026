                    <div className="flex-shrink-0 text-right">
                        <p className="text-[10px] text-slate-400 uppercase tracking-widest mb-1">Meta</p>
                        <p className="text-yellow-400 text-sm" style={{fontWeight:700}}>Principalidad & Rentabilidad</p>
                    </div>
                </div>

                {/* Three pillars */}
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    {pillars.map((p, idx) => {
                        const t = themeStyles[p.theme];
                        const PIcon = pillarIcons[idx];
                        return (
                            <div key={idx} className={`bg-white rounded-xl border-l-4 ${t.accent} shadow-sm flex flex-col overflow-hidden`}>
                                <div className="p-5 flex-grow flex flex-col">
                                    {/* Header */}
                                    <div className="flex justify-between items-start mb-4">
                                        <div>
                                            <h3 className="text-base text-slate-900 leading-tight" style={{fontWeight:700}}>{p.title}</h3>
                                            <p className={`text-[10px] font-700 uppercase tracking-wider mt-0.5 ${t.text}`} style={{fontWeight:700}}>{p.subtitle}</p>
                                        </div>
                                        <div className={`${t.iconBg} text-white p-2.5 rounded-lg shadow-sm flex-shrink-0 ml-3`}>
                                            <PIcon size={18} className="text-white" style={{stroke:'white'}}/>
                                        </div>
                                    </div>
                                    {/* Tesis */}
                                    <div className="mb-4 bg-slate-50 p-3 rounded-lg border border-slate-100">
